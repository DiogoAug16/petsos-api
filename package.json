{
  "name": "backend",
  "version": "1.1.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "node --test src/modules/map-tiles/map-tiles.util.test.js",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "backfill:complaint-geohashes": "node scripts/backfill-complaint-geohashes.js",
    "backfill:map-tile-stats": "node scripts/backfill-map-tile-stats.js",
    "backfill:complaint-thumbnails": "node scripts/backfill-complaint-thumbnails.js",
    "bench:complaints": "sh -c 'BENCH_URL=${BENCH_URL:-http://localhost:3030}; autocannon -d 15 -c 20 \"$BENCH_URL/api/complaints?limit=50\"'",
    "bench:map-index": "sh -c 'BENCH_URL=${BENCH_URL:-http://localhost:3030}; autocannon -d 15 -c 20 \"$BENCH_URL/api/complaints/map/tiles-index?lat=-15.62&lng=-56.05&radiusKm=10&z=12\"'",
    "bench:openapi": "sh -c 'BENCH_URL=${BENCH_URL:-http://localhost:3030}; autocannon -d 10 -c 10 \"$BENCH_URL/api/openapi.json\"'",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "geofire-common": "^6.0.0",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.35.2",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autocannon": "^8.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.3"
  }
}
